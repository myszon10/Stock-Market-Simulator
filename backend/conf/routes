# Routes
# This file defines all application routes (Higher priority routes first)
# https://www.playframework.com/documentation/latest/ScalaRouting
# ~~~~

POST    /api/auth/register          controllers.AuthController.register()
POST    /api/auth/login             controllers.AuthController.login()
POST    /api/auth/logout            controllers.AuthController.logout()

GET     /api/stocks                 controllers.StockController.stocks()
GET     /api/stocks/:symbol/quote   controllers.StockController.quote(symbol: String)

POST    /api/orders/buy             controllers.OrderController.buy()